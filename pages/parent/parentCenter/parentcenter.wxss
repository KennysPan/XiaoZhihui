page {
  background: linear-gradient(135deg, #87CEFA 0%, #E6F7FF 50%, #ffffff 100%);
  font-family: "PingFang SC", sans-serif;
  min-height: 100vh;
  background-attachment: fixed;
}

.container {
  min-height: 100vh;
  padding: 0 24rpx;
  padding-bottom: calc(300rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: transparent;
  display: flex;
  flex-direction: column;
}

/* 顶部占位区域 */
.top-placeholder {
  height: 136rpx;
  width: 100%;
  flex-shrink: 0;
}

/* 底部安全区域 */
.bottom-safe {
  height: calc(260rpx + env(safe-area-inset-bottom));
  width: 100%;
  flex-shrink: 0;
}

/* 加载状态 */
.loading-state {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 400rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 通用卡片样式 */
.main-card {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  border-radius: 36rpx;
  margin-bottom: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

/* 家长信息卡片 */
.parent-card {
  display: flex;
  align-items: center;
  position: relative;
}

.avatar-box {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #7ee7bc 0%, #5fd9a8 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow: 0 8rpx 20rpx rgba(126, 231, 188, 0.25);
  flex-shrink: 0;
}

.avatar-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

.avatar-edit {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
}

.info-content {
  flex: 1;
  margin-left: 24rpx;
  overflow: hidden;
}

.info-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.info-relation {
  font-size: 26rpx;
  color: #5fd9a8;
  margin-bottom: 6rpx;
}

.info-phone {
  font-size: 26rpx;
  color: #999;
}

.edit-btn {
  padding: 12rpx 28rpx;
  background: rgba(126, 231, 188, 0.15);
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #5fd9a8;
  flex-shrink: 0;
}

.edit-btn:active {
  background: rgba(126, 231, 188, 0.3);
}

/* 卡片头部 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid rgba(126, 231, 188, 0.25);
}

.section-title-wrap {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  position: relative;
  padding-left: 16rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 28rpx;
  background: linear-gradient(135deg, #7ee7bc 0%, #5fd9a8 100%);
  border-radius: 4rpx;
}

.section-count {
  font-size: 24rpx;
  color: #999;
}

.section-more {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 26rpx;
  color: #5fd9a8;
  padding: 8rpx 16rpx;
  border-radius: 30rpx;
}

.section-more:active {
  background: rgba(126, 231, 188, 0.1);
}

.more-arrow {
  font-size: 32rpx;
}

/* 孩子列表 */
.children-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.child-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: rgba(249, 249, 249, 0.6);
  border-radius: 28rpx;
  transition: all 0.2s ease;
}

.child-item:active {
  background: rgba(240, 240, 240, 0.8);
  transform: scale(0.98);
}

.child-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #7ee7bc 0%, #5fd9a8 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.child-avatar text {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.child-info {
  flex: 1;
  min-width: 0;
}

.child-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.child-class {
  font-size: 24rpx;
  color: #999;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.child-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* 请假审批列表 */
.approve-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  max-height: 500rpx;
  overflow-y: auto;
}

.approve-item {
  padding: 24rpx;
  background: rgba(249, 249, 249, 0.6);
  border-radius: 28rpx;
  transition: all 0.2s ease;
}

.approve-item:active {
  background: rgba(240, 240, 240, 0.8);
}

.approve-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.approve-child {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.approve-status {
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
}

.status-1 {
  background: #fffbe6;
  color: #faad14;
}

.status-2 {
  background: #f6ffed;
  color: #52c41a;
}

.status-3 {
  background: #fff1f0;
  color: #ff4d4f;
}

.approve-type {
  font-size: 26rpx;
  color: #5fd9a8;
  display: block;
  margin-bottom: 8rpx;
}

.approve-time {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.approve-reason {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 功能卡片 */
.function-card {
  padding: 8rpx 0;
}

.function-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
}

.function-item:active {
  background: rgba(0, 0, 0, 0.02);
}

.function-left {
  flex: 1;
}

.function-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
}

.function-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.function-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.function-divider {
  height: 1rpx;
  background: rgba(0, 0, 0, 0.05);
  margin: 0 32rpx;
}

/* 退出登录按钮 */
.logout-wrapper {
  margin-top: 56rpx;
  padding: 0 8rpx;
  position: relative;
  z-index: 2;
}

.logout-btn {
  width: 100%;
  height: 96rpx;
  background: rgba(255, 77, 79, 0.08);
  border: 2rpx solid rgba(255, 77, 79, 0.25);
  border-radius: 48rpx;
  color: #ff4d4f;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logout-btn::after {
  border: none;
}

.logout-btn:active {
  background: rgba(255, 77, 79, 0.15);
  transform: scale(0.98);
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 48rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-bottom: 24rpx;
}

.empty-add-btn {
  width: 240rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #7ee7bc 0%, #5fd9a8 100%);
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
  border: none;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 85%;
  max-width: 650rpx;
  background: #fff;
  border-radius: 40rpx;
  overflow: hidden;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  width: 50rpx;
  height: 50rpx;
  background: #f5f5f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #999;
}

.modal-body {
  padding: 30rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.detail-item {
  display: flex;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.detail-item:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.detail-label {
  width: 140rpx;
  font-size: 28rpx;
  color: #999;
  flex-shrink: 0;
}

.detail-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  word-break: break-all;
  line-height: 1.5;
}

.detail-value.status-1 {
  color: #faad14;
}

.detail-value.status-2 {
  color: #52c41a;
}

.detail-value.status-3 {
  color: #ff4d4f;
}

.modal-footer {
  padding: 20rpx 30rpx 30rpx;
}

.modal-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #7ee7bc 0%, #5fd9a8 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 40rpx;
  border: none;
}

.modal-btn::after {
  border: none;
}

/* 毛玻璃效果兼容 */
@supports (backdrop-filter: blur(10px)) {
  .main-card {
    background: rgba(255, 255, 255, 0.85);
  }
}

@supports not (backdrop-filter: blur(10px)) {
  .main-card {
    background: rgba(255, 255, 255, 0.98);
  }
}

/* 响应式适配 */
@media (max-width: 375px) {
  .container {
    padding: 0 16rpx;
  }
  
  .top-placeholder {
    height: 160rpx;
  }
  
  .main-card {
    padding: 24rpx;
  }
  
  .avatar-box {
    width: 100rpx;
    height: 100rpx;
  }
  
  .avatar-text {
    font-size: 40rpx;
  }
  
  .info-name {
    font-size: 32rpx;
  }
  
  .edit-btn {
    padding: 10rpx 20rpx;
    font-size: 24rpx;
  }
}
