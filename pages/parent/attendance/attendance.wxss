/* 统一返回按钮样式 */
.custom-back {
  position: fixed;
  top: 80rpx;
  left: 30rpx;
  display: flex;
  align-items: center;
  z-index: 1000;
  background: rgba(255, 255, 255, 0.9);
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.back-icon {
  width: 16rpx;
  height: 16rpx;
  border-left: 4rpx solid #333;
  border-bottom: 4rpx solid #333;
  transform: rotate(45deg);
  margin-right: 12rpx;
}

.back-text {
  font-size: 28rpx;
  color: #333;
}

/* 页面头部标题 */
.page-header {
  margin-bottom: 30rpx;
  padding-top: 20rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
  text-align: center;
}

/* 调整容器内边距 */
.container {
  min-height: 100vh;
  padding: 20rpx;
  padding-top: 140rpx;
  padding-bottom: 60rpx;
  box-sizing: border-box;
  background: transparent;
}

page {
  background: linear-gradient(135deg, #87CEFA 0%, #E6F7FF 50%, #ffffff 100%);
  font-family: "PingFang SC", sans-serif;
  min-height: 100vh;
  background-attachment: fixed;
}

/* 隐藏原有的头部 */
.header {
  display: none;
}

/* 孩子选择器 - 毛玻璃效果 */
.child-selector {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  border-radius: 30rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.child-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  font-weight: 500;
}

.child-list {
  white-space: nowrap;
  width: 100%;
}

.child-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 160rpx;
  margin-right: 30rpx;
  padding: 20rpx 10rpx;
  border-radius: 20rpx;
  background: rgba(249, 249, 249, 0.9);
  transition: all 0.3s ease;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.child-item.active {
  background: linear-gradient(135deg, #7ee7bc 0%, #5fd9a8 100%);
  box-shadow: 0 8rpx 20rpx rgba(94, 217, 168, 0.3);
}

.child-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-bottom: 10rpx;
  background: #e0e0e0;
  border: 2rpx solid #fff;
}

.child-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.child-class {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.child-item.active .child-name,
.child-item.active .child-class {
  color: #fff;
}

/* 统计卡片 */
.stats-card {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  border-radius: 30rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.stats-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.stats-date {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 20rpx;
  background: rgba(245, 245, 245, 0.8);
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666;
}

.arrow-down {
  font-size: 20rpx;
  margin-left: 6rpx;
}

.stats-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.stat-item {
  width: 33.33%;
  text-align: center;
  margin-bottom: 20rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
  color: #333;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

/* 考勤列表 */
.attendance-list {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  border-radius: 30rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(240, 240, 240, 0.8);
}

.list-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.list-tip {
  font-size: 24rpx;
  color: #999;
}

.attendance-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(245, 245, 245, 0.8);
  transition: all 0.2s ease;
}

.attendance-item:active {
  background: rgba(249, 249, 249, 0.8);
  margin: 0 -20rpx;
  padding: 24rpx 20rpx;
  border-radius: 20rpx;
}

.item-left {
  flex: 2;
}

.item-date {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  display: block;
}

.item-weekday {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
  display: block;
}

.item-center {
  flex: 1.5;
  text-align: center;
}

.status-badge {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-1 {
  background: #f6ffed;
  color: #52c41a;
  border: 1rpx solid #b7eb8f;
}

.status-2 {
  background: #fffbe6;
  color: #faad14;
  border: 1rpx solid #ffe58f;
}

.status-3 {
  background: #fff7e6;
  color: #fa8c16;
  border: 1rpx solid #ffd591;
}

.status-4 {
  background: #fff1f0;
  color: #ff4d4f;
  border: 1rpx solid #ffccc7;
}

.status-5 {
  background: #e6f7ff;
  color: #1890ff;
  border: 1rpx solid #91d5ff;
}

.item-right {
  flex: 1.5;
  text-align: right;
}

.check-time {
  font-size: 24rpx;
  color: #666;
  display: block;
  line-height: 1.6;
}

.leave-tag {
  font-size: 24rpx;
  color: #1890ff;
  background: #e6f7ff;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  display: inline-block;
}

.item-arrow {
  width: 50rpx;
  text-align: right;
}

.arrow-icon {
  font-size: 28rpx;
  color: #ccc;
}

/* 考勤轨迹弹窗 */
.timeline-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.timeline-modal {
  width: 85%;
  max-width: 700rpx;
  max-height: 80vh;
  background: #fff;
  border-radius: 40rpx;
  overflow: hidden;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

/* 弹窗头部 */
.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background: #fff;
}

.modal-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.title-icon {
  font-size: 32rpx;
}
.title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 50%;
  font-size: 32rpx;
  color: #999;
}

.modal-close:active {
  background: #e8e8e8;
}

/* 弹窗内容 */
.modal-content {
  max-height: 60vh;
  padding: 0 30rpx;
}

/* 状态摘要卡片 */
.status-summary {
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 20rpx;
}

.summary-status {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  border: 1rpx solid;
}

.summary-icon {
  font-size: 28rpx;
}

.summary-text {
  font-size: 28rpx;
  font-weight: 500;
}

.summary-time {
  font-size: 26rpx;
  color: #666;
}

/* 时间线 */
.timeline-container {
  position: relative;
  padding: 30rpx 0;
}

.timeline-item {
  position: relative;
  padding-bottom: 40rpx;
  display: flex;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin-right: 30rpx;
  flex-shrink: 0;
  margin-top: 8rpx;
  position: relative;
  z-index: 2;
  box-shadow: 0 0 0 4rpx rgba(0, 0, 0, 0.05);
}

.timeline-item::before {
  content: '';
  position: absolute;
  left: 9rpx;
  top: 28rpx;
  bottom: -20rpx;
  width: 2rpx;
  background: #e8e8e8;
  z-index: 1;
}

.timeline-item:last-child::before {
  display: none;
}

.timeline-content {
  flex: 1;
  padding-bottom: 20rpx;
}

.timeline-time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.timeline-title-text {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.timeline-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
}

/* 温馨提示 */
.timeline-tip {
  padding: 30rpx 0;
  text-align: center;
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.tip-icon {
  font-size: 28rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #999;
}

/* 弹窗底部 */
.modal-footer {
  padding: 20rpx 30rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.modal-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: linear-gradient(135deg, #7ee7bc 0%, #5fd9a8 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 40rpx;
  border: none;
}

.modal-btn::after {
  border: none;
}

.modal-btn:active {
  opacity: 0.8;
}

/* 日期选择器弹窗 */
.date-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.date-picker-modal {
  width: 80%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 30rpx;
  overflow: hidden;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.picker-close {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
}

.picker-content {
  padding: 30rpx;
}

.picker-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.picker-label {
  font-size: 28rpx;
  color: #666;
}

.picker-value {
  font-size: 28rpx;
  color: #333;
  padding: 10rpx 20rpx;
  background: #f9f9f9;
  border-radius: 20rpx;
}

.picker-footer {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.picker-btn {
  flex: 1;
  height: 90rpx;
  line-height: 90rpx;
  text-align: center;
  font-size: 28rpx;
  background: none;
  border: none;
  border-radius: 0;
}

.picker-btn.cancel {
  color: #999;
  border-right: 1rpx solid #f0f0f0;
}

.picker-btn.confirm {
  color: #7ee7bc;
  font-weight: bold;
}

.picker-btn::after {
  border: none;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 响应式适配 - 小屏幕 */
@media (max-width: 375px) {
  .container {
    padding: 15rpx;
    padding-top: 140rpx;
  }
  
  .child-item {
    width: 140rpx;
    margin-right: 20rpx;
  }
  
  .stat-value {
    font-size: 32rpx;
  }
  
  .item-date {
    font-size: 26rpx;
  }
  
  .status-badge {
    padding: 6rpx 16rpx;
    font-size: 22rpx;
  }
}

/* 响应式适配 - 大屏幕 */
@media (min-width: 768px) {
  .container {
    max-width: 750rpx;
    margin: 0 auto;
    padding-top: 140rpx;
  }
  
  .child-item {
    width: 180rpx;
  }
  
  .stat-value {
    font-size: 48rpx;
  }
}

/* 毛玻璃效果兼容处理 */
@supports (backdrop-filter: blur(10px)) {
  .child-selector,
  .stats-card,
  .attendance-list {
    background: rgba(255, 255, 255, 0.85);
  }
}

/* 不支持毛玻璃的降级方案 */
@supports not (backdrop-filter: blur(10px)) {
  .child-selector,
  .stats-card,
  .attendance-list {
    background: rgba(255, 255, 255, 0.98);
  }
}