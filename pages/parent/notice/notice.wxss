/* 页面背景 - 统一风格 */
page {
  background: linear-gradient(135deg, #87CEFA 0%, #E6F7FF 50%, #ffffff 100%);
  min-height: 100vh;
  background-attachment: fixed;
}

/* 统一返回按钮样式 */
.custom-back {
  position: fixed;
  top: 80rpx;
  left: 30rpx;
  display: flex;
  align-items: center;
  z-index: 1000;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.back-icon {
  width: 16rpx;
  height: 16rpx;
  border-left: 4rpx solid #333;
  border-bottom: 4rpx solid #333;
  transform: rotate(45deg);
  margin-right: 12rpx;
}

.back-text {
  font-size: 28rpx;
  color: #333;
}

.page-header {
  margin-bottom: 30rpx;
  padding-top: 20rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
  text-align: center;
}

.container {
  min-height: 100vh;
  padding: 20rpx;
  padding-top: 140rpx;
  padding-bottom: 60rpx;
  box-sizing: border-box;
}

/* 公告列表 */
.notice-list {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  border-radius: 30rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.notice-item {
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: background 0.2s;
}

.notice-item:active {
  background: rgba(126, 231, 188, 0.1);
}

.notice-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.notice-summary {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
  margin-bottom: 16rpx;
  word-break: break-word;
  overflow-wrap: break-word;
}

.notice-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.notice-time {
  font-size: 24rpx;
  color: #999;
}

.right-tags {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.view-count {
  font-size: 22rpx;
  color: #aaa;
}

.notice-tag {
  background: #ff7875;
  color: #fff;
  padding: 4rpx 16rpx;
  border-radius: 30rpx;
  font-size: 22rpx;
}

/* 加载状态 */
.loading-state {
  text-align: center;
  padding: 100rpx 0;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 毛玻璃兼容 */
@supports (backdrop-filter: blur(10px)) {
  .custom-back,
  .notice-list {
    background: rgba(255, 255, 255, 0.88);
  }
}

@supports not (backdrop-filter: blur(10px)) {
  .custom-back,
  .notice-list {
    background: rgba(255, 255, 255, 0.98);
  }
}