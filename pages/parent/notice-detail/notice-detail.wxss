page {
  background: linear-gradient(135deg, #87CEFA 0%, #E6F7FF 50%, #ffffff 100%);
  min-height: 100vh;
  background-attachment: fixed;
}

.custom-back {
  position: fixed;
  top: 80rpx;
  left: 30rpx;
  display: flex;
  align-items: center;
  z-index: 1000;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.back-icon {
  width: 16rpx;
  height: 16rpx;
  border-left: 4rpx solid #333;
  border-bottom: 4rpx solid #333;
  transform: rotate(45deg);
  margin-right: 12rpx;
}

.back-text {
  font-size: 28rpx;
  color: #333;
}

.container {
  min-height: 100vh;
  padding: 20rpx;
  padding-top: 160rpx;     /* 增加顶部内边距，让内容下移 */
  padding-bottom: 40rpx;
  box-sizing: border-box;
}

.loading-state {
  text-align: center;
  padding: 200rpx 0;
  color: #999;
}

.detail-container {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  border-radius: 40rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  margin-top: 20rpx;       /* 增加顶部外边距 */
}

.detail-header {
  padding: 36rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.title-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.important-tag {
  background: linear-gradient(135deg, #ff7875 0%, #ff4d4f 100%);
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
}

.detail-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.4;
  flex: 1;
}

.meta-info {
  display: flex;
  gap: 30rpx;
}

.meta-date, .meta-views {
  font-size: 24rpx;
  color: #999;
}

.detail-content {
  padding: 32rpx;
  max-height: calc(100vh - 540rpx);  /* 调整高度以适应新的间距 */
  overflow-y: auto;
}

.detail-content rich-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
}

.detail-footer {
  padding: 24rpx 32rpx 32rpx;
  border-top: 1rpx solid #f0f0f0;
}

.back-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #7ee7bc 0%, #5fd9a8 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}

.back-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}