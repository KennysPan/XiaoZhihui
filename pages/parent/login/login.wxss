/* 页面整体样式 */
page {
  background-color: #ffffff; 
  overflow-x: hidden;
  overflow-y: hidden;
  height: 100vh;
}

/* 页面主容器 */
.login-page {
  background: linear-gradient(to bottom, #88cdf8, #ffffff);
  position: relative;
  height: 100vh;
  width: 100vw;
  overflow: hidden;
  box-sizing: border-box;
  padding: calc(228rpx + env(safe-area-inset-top)) 40rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Logo容器 */
.icon-wrapper {
  position: relative;
  display: flex;
  z-index: 1;
  align-items: center;
  justify-content: center;
  margin: 0 0 22rpx;
  flex-shrink: 0;
}

.icon {
  width: 160rpx;
  height: 160rpx;
}

/* 标题 */
.header {
  text-align: center;
  margin: 0 0 32rpx;
  flex-shrink: 0;
}

.title {
  font-size: 42rpx;
  font-weight: bold;
  color: #333;
}

/* 登录卡片 */
.login-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 44rpx 40rpx;
  width: 85%;
  max-width: 600rpx;
  margin: 0 auto;
  background-color: #ffffff;
  border-radius: 64rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 10;
  flex-shrink: 0;
}

.login-title {
  font-size: 42rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 36rpx;
}

/* 输入框通用样式 */
.input-item {
  display: flex;
  align-items: center;
  width: 100%;
  height: 86rpx;
  background-color: #f7f7f7;
  border-radius: 12rpx;
  padding: 0 30rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.label {
  font-size: 28rpx;
  color: #666666;
  width: 100rpx;
}

.input-field {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.login-actions-row {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: -4rpx;
  margin-bottom: 28rpx;
}

.quick-login-btn {
  width: 140rpx;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0;
  margin: 0;
  background: #ecfff7;
  color: #39b889;
  border-radius: 26rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.quick-login-btn::after {
  border: none;
}

/* 忘记密码 */
.forget-pwd {
  font-size: 24rpx;
  color: #74E2B6;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 86rpx;
  background: linear-gradient(to right, #76e6b1, #51d1a5);
  color: white;
  font-size: 32rpx;
  border-radius: 45rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(118, 230, 177, 0.4);
}

/* 底部装饰图 */
.bottomIcon {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 58%;
  opacity: 0.3;
  z-index: 0;
  pointer-events: none;
}

.role-back {
  position: absolute;
  left: 52rpx;
  top: calc(112rpx + env(safe-area-inset-top));
  z-index: 20;
  display: flex;
  align-items: center;
  height: 64rpx;
  padding: 0 20rpx 0 12rpx;
  background: rgba(255, 255, 255, 0.78);
  border-radius: 32rpx;
  color: #1E3A8A;
  box-shadow: 0 8rpx 20rpx rgba(30, 58, 138, 0.12);
}

.role-back.parent-exit-btn {
  left: 30rpx;
  height: 72rpx;
  padding: 0 22rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(38, 50, 56, 0.08);
  border-radius: 36rpx;
  color: #263238;
  box-shadow: 0 8rpx 20rpx rgba(38, 50, 56, 0.08);
}

.role-back-icon {
  font-size: 42rpx;
  line-height: 1;
  margin-right: 4rpx;
}

.role-back-text {
  font-size: 28rpx;
  font-weight: 600;
}
