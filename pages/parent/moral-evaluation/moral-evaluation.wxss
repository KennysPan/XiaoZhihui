page {
  background: linear-gradient(135deg, #87CEFA 0%, #E6F7FF 50%, #ffffff 100%);
  min-height: 100vh;
  background-attachment: fixed;
}

.custom-back {
  position: fixed;
  top: 80rpx;
  left: 30rpx;
  display: flex;
  align-items: center;
  z-index: 1000;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.back-icon {
  width: 16rpx;
  height: 16rpx;
  border-left: 4rpx solid #333;
  border-bottom: 4rpx solid #333;
  transform: rotate(45deg);
  margin-right: 12rpx;
}

.back-text {
  font-size: 28rpx;
  color: #333;
}

.container {
  min-height: 100vh;
  padding: 20rpx;
  padding-top: 140rpx;
  padding-bottom: 60rpx;
  box-sizing: border-box;
}

.page-header {
  text-align: center;
  margin-bottom: 30rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.page-subtitle {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 8rpx;
}

/* 孩子选择器 */
.child-selector {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  border-radius: 30rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.child-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.child-list {
  white-space: nowrap;
  width: 100%;
}

.child-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 140rpx;
  margin-right: 24rpx;
  padding: 16rpx 8rpx;
  border-radius: 24rpx;
  background: rgba(249, 249, 249, 0.8);
  transition: all 0.3s ease;
}

.child-item.active {
  background: linear-gradient(135deg, rgba(126, 231, 188, 0.2), rgba(95, 217, 168, 0.2));
  border: 1rpx solid rgba(126, 231, 188, 0.5);
}

.child-avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.child-avatar text {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.child-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.child-class {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 综合评级卡片 */
.rating-card {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  border-radius: 30rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.rating-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.rating-label {
  font-size: 28rpx;
  color: #666;
}

.rating-value {
  font-size: 32rpx;
  font-weight: bold;
  padding: 8rpx 24rpx;
  border-radius: 40rpx;
}

.rating-value.grade-A {
  background: rgba(82, 196, 26, 0.15);
  color: #52c41a;
}

.rating-value.grade-B {
  background: rgba(250, 173, 20, 0.15);
  color: #faad14;
}

.rating-value.grade-C {
  background: rgba(255, 77, 79, 0.15);
  color: #ff4d4f;
}

.rating-score {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 16rpx;
}

.score-number {
  font-size: 72rpx;
  font-weight: bold;
  color: #333;
}

.score-total {
  font-size: 28rpx;
  color: #999;
  margin-left: 8rpx;
}

.rating-comment {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

/* 指标卡片 */
.indicator-card, .record-card {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  border-radius: 30rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid rgba(126, 231, 188, 0.3);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-count {
  font-size: 24rpx;
  color: #999;
  font-weight: normal;
}

.indicator-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.indicator-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.indicator-item:last-child {
  border-bottom: none;
}

.indicator-info {
  flex: 1;
}

.indicator-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
}

.indicator-desc {
  font-size: 22rpx;
  color: #999;
}

.indicator-score {
  flex-shrink: 0;
}

.score-value {
  font-size: 32rpx;
  font-weight: bold;
}

.score-unit {
  font-size: 24rpx;
  color: #999;
}

/* 历史记录 */
.record-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-item {
  padding: 20rpx;
  background: rgba(249, 249, 249, 0.6);
  border-radius: 24rpx;
  transition: all 0.2s ease;
}

.record-item:active {
  background: rgba(240, 240, 240, 0.8);
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.record-term {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.record-grade {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 30rpx;
}

.record-grade.grade-A {
  background: rgba(82, 196, 26, 0.15);
  color: #52c41a;
}

.record-grade.grade-B {
  background: rgba(250, 173, 20, 0.15);
  color: #faad14;
}

.record-grade.grade-C {
  background: rgba(255, 77, 79, 0.15);
  color: #ff4d4f;
}

.record-comment {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.record-footer {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #999;
}

/* 加载和空状态 */
.loading-state, .empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #bbb;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 85%;
  max-width: 650rpx;
  background: #fff;
  border-radius: 40rpx;
  overflow: hidden;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  width: 50rpx;
  height: 50rpx;
  background: #f5f5f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #999;
}

.modal-body {
  padding: 30rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.detail-item {
  display: flex;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.detail-item:last-child {
  border-bottom: none;
}

.detail-label {
  width: 140rpx;
  font-size: 28rpx;
  color: #999;
  flex-shrink: 0;
}

.detail-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  word-break: break-all;
}

.detail-value.grade-A {
  color: #52c41a;
  font-weight: bold;
}

.detail-value.grade-B {
  color: #faad14;
  font-weight: bold;
}

.detail-value.grade-C {
  color: #ff4d4f;
  font-weight: bold;
}

.detail-section {
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.section-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.indicator-detail-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.indicator-detail-item {
  width: calc(50% - 8rpx);
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.indicator-detail-item .indicator-name {
  font-size: 26rpx;
  color: #666;
}

.indicator-detail-item .indicator-score {
  font-size: 26rpx;
  font-weight: 500;
  color: #5fd9a8;
}

.modal-footer {
  padding: 20rpx 30rpx 30rpx;
}

.modal-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #7ee7bc 0%, #5fd9a8 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 40rpx;
  border: none;
}

/* 毛玻璃兼容 */
@supports (backdrop-filter: blur(10px)) {
  .child-selector,
  .rating-card,
  .indicator-card,
  .record-card {
    background: rgba(255, 255, 255, 0.85);
  }
}