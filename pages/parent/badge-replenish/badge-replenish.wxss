page {
  background: linear-gradient(135deg, #87CEFA 0%, #E6F7FF 50%, #ffffff 100%);
  min-height: 100vh;
  background-attachment: fixed;
}

.container {
  min-height: 100vh;
  padding: 20rpx;
  padding-top: 140rpx;
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

/* 统一返回按钮 */
.custom-back {
  position: fixed;
  top: 80rpx;
  left: 30rpx;
  display: flex;
  align-items: center;
  z-index: 1000;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.back-icon {
  width: 16rpx;
  height: 16rpx;
  border-left: 4rpx solid #333;
  border-bottom: 4rpx solid #333;
  transform: rotate(45deg);
  margin-right: 12rpx;
}

.back-text {
  font-size: 28rpx;
  color: #333;
}

/* 页面头部 */
.page-header {
  text-align: center;
  margin-bottom: 30rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.page-subtitle {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-top: 8rpx;
}

/* 校徽卡片 */
.badge-card {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  border-radius: 30rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  display: flex;
  gap: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.badge-image-wrapper {
  width: 160rpx;
  height: 160rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: #f5f5f5;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.badge-image {
  width: 100%;
  height: 100%;
}

.badge-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.badge-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.badge-desc {
  font-size: 24rpx;
  color: #999;
  line-height: 1.4;
}

.badge-price {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.price-symbol {
  font-size: 26rpx;
  color: #ff6b6b;
}

.price-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff6b6b;
}

.price-unit {
  font-size: 24rpx;
  color: #999;
}

/* 分区卡片 */
.section-card {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  border-radius: 30rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  position: relative;
  padding-left: 20rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 28rpx;
  background: linear-gradient(135deg, #7ee7bc 0%, #5fd9a8 100%);
  border-radius: 3rpx;
}

/* 全选按钮 */
.select-all {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.select-all-text {
  font-size: 26rpx;
  color: #666;
}

/* 复选框 */
.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  background: #fff;
  transition: all 0.2s;
}

.checkbox.checked {
  background: linear-gradient(135deg, #7ee7bc 0%, #5fd9a8 100%);
  border-color: #5fd9a8;
  position: relative;
}

.checkbox.checked::after {
  content: '✓';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 22rpx;
  color: #fff;
}

/* 孩子列表 */
.children-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.child-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.child-item:last-child {
  border-bottom: none;
}

.child-select {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.child-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #7ee7bc 0%, #5fd9a8 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}

.child-info {
  flex: 1;
}

.child-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  display: block;
}

.child-class {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
  display: block;
}

/* 数量选择器 */
.quantity-control {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #f8f9fc;
  padding: 10rpx 20rpx;
  border-radius: 50rpx;
}

.qty-btn {
  width: 48rpx;
  height: 48rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  color: #5fd9a8;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.05);
}

.qty-btn:active {
  background: #eef2f7;
  transform: scale(0.94);
}

.qty-number {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  min-width: 50rpx;
  text-align: center;
}

/* 选择器输入框 */
.picker-input {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.picker-input .placeholder {
  color: #ccc;
}

.picker-arrow {
  font-size: 36rpx;
  color: #ccc;
  font-weight: 300;
}

/* 备注输入框 */
.remark-input {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  background: #f8f9fc;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  margin-top: 16rpx;
}

.remark-placeholder {
  color: #ccc;
  font-size: 26rpx;
}

.remark-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #ccc;
  margin-top: 12rpx;
}

/* 订单汇总卡片 */
.summary-card {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  border-radius: 30rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.summary-row.total {
  margin-top: 16rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #f0f0f0;
}

.summary-label {
  font-size: 28rpx;
  color: #666;
}

.summary-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.summary-price {
  font-size: 44rpx;
  font-weight: bold;
  color: #ff6b6b;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20px);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.total-info {
  flex: 1;
}

.total-label {
  font-size: 28rpx;
  color: #666;
}

.total-price {
  font-size: 48rpx;
  font-weight: bold;
  color: #ff6b6b;
}

.submit-btn {
  width: 260rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #7ee7bc 0%, #5fd9a8 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(126, 231, 188, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn.disabled {
  opacity: 0.5;
  transform: none;
}

.submit-btn:active {
  transform: scale(0.96);
}

/* 空状态 */
.empty-children {
  text-align: center;
  padding: 60rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  display: block;
}

.empty-desc {
  font-size: 24rpx;
  color: #ccc;
  display: block;
  margin-top: 12rpx;
}

/* 加载状态 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

/* 毛玻璃兼容 */
@supports (backdrop-filter: blur(10px)) {
  .custom-back,
  .badge-card,
  .section-card,
  .summary-card,
  .bottom-bar {
    background: rgba(255, 255, 255, 0.88);
  }
}