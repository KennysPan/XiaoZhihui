/* pages/repassword/repassword.wxss */
page {
  background-color: #f8fbfb;
}

/* 导航返回 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  z-index: 100;
}

.back-btn {
  position: absolute;
  left: 30rpx;
  display: flex;
  align-items: center;
  width: 60rpx;
}

.back-icon {
  width: 24rpx;
  height: 24rpx;
  border-left: 5rpx solid #333;
  border-bottom: 5rpx solid #333;
  transform: rotate(45deg);
}

/* 内容布局 */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 60rpx;
}

.title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-top: 100rpx;
  line-height: 1.5;
}

.phone-display {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin: 80rpx 0 120rpx 0;
  letter-spacing: 2rpx;
}

/* 按钮样式 */
.button-group {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 10;
}

.btn {
  width: 400rpx;
  height: 100rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #fff;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 20rpx rgba(126, 231, 188, 0.4);
  transition: all 0.1s ease;
}

.copy-btn, .back-page-btn {
  background: #7ee7bc; /* 这里的绿色参考图片效果 */
}

/* 点击反馈效果 */
.item-hover {
  background-color: #6cd4a9 !important;
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1) !important;
}

/* 底部背景图 */
.footer-bg {
  position: fixed;
  bottom: 0;
  right: 0;
  width: 450rpx;
  opacity: 0.3;
  z-index: 1;
}