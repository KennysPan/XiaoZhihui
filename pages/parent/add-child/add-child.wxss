page {
  background: linear-gradient(135deg, #87CEFA 0%, #E6F7FF 50%, #ffffff 100%);
  min-height: 100vh;
  background-attachment: fixed;
}

.custom-back {
  position: fixed;
  top: 80rpx;
  left: 30rpx;
  display: flex;
  align-items: center;
  z-index: 1000;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.back-icon {
  width: 16rpx;
  height: 16rpx;
  border-left: 4rpx solid #333;
  border-bottom: 4rpx solid #333;
  transform: rotate(45deg);
  margin-right: 12rpx;
}

.back-text {
  font-size: 28rpx;
  color: #333;
}

.container {
  min-height: 100vh;
  padding: 24rpx;
  padding-top: 140rpx;
  padding-bottom: 80rpx;
  box-sizing: border-box;
}

.page-header {
  text-align: center;
  margin-bottom: 30rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.page-subtitle {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-top: 8rpx;
}

/* 步骤指示器 */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 60rpx;
  padding: 0 20rpx;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.step-num {
  width: 56rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: bold;
  color: #aaa;
  transition: all 0.3s ease;
}

.step.active .step-num {
  background: linear-gradient(135deg, #7ee7bc 0%, #5fd9a8 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(126, 231, 188, 0.3);
}

.step.done .step-num {
  background: #5fd9a8;
  color: #fff;
}

.step-text {
  font-size: 22rpx;
  color: #aaa;
}

.step.active .step-text {
  color: #5fd9a8;
  font-weight: 500;
}

.step-line {
  width: 80rpx;
  height: 4rpx;
  background: rgba(0, 0, 0, 0.1);
  margin-bottom: 40rpx;
  transition: all 0.3s ease;
}

.step-line.active {
  background: linear-gradient(90deg, #7ee7bc, #5fd9a8);
}

/* 步骤面板 */
.step-panel {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  border-radius: 40rpx;
  padding: 48rpx 32rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  transition: all 0.4s ease;
  opacity: 0;
  transform: translateX(40rpx);
  display: none;
}

.step-panel.active {
  display: block;
  opacity: 1;
  transform: translateX(0);
}

.step-panel.complete {
  display: none;
}

/* 步骤1样式 */
.panel-icon {
  font-size: 64rpx;
  text-align: center;
  margin-bottom: 16rpx;
}

.panel-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 12rpx;
}

.panel-desc {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  margin-bottom: 48rpx;
}

.id-input-wrapper {
  margin-bottom: 48rpx;
}

.id-input {
  width: 90%;
  height: 88rpx;
  margin: 0 auto;
  padding: 0 28rpx;
  background: #f8f9fc;
  border-radius: 28rpx;
  font-size: 32rpx;
  line-height: 88rpx;
  letter-spacing: 2rpx;
  text-align: center;
  display: block;
  box-sizing: border-box;
  border: 2rpx solid #e8ecf0;
  transition: all 0.2s ease;
}

.id-input-placeholder {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  color: #b8c0cc;
}

.id-input:focus {
  border-color: #7ee7bc;
  background: #fff;
  box-shadow: 0 0 0 4rpx rgba(126, 231, 188, 0.1);
}

.id-format-hint {
  margin-top: 16rpx;
  text-align: center;
}

.hint-error {
  font-size: 24rpx;
  color: #ff4d4f;
}

.hint-success {
  font-size: 24rpx;
  color: #5fd9a8;
}

.next-btn,
.demo-btn,
.back-btn,
.confirm-btn,
.continue-btn,
.finish-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  line-height: normal;
}

.next-btn {
  width: 80%;
  margin: 0 auto;
  height: 96rpx;
  background: linear-gradient(135deg, #7ee7bc 0%, #5fd9a8 100%);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
	
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(126, 231, 188, 0.3);
  transition: all 0.2s ease;
}

.next-btn:active {
  transform: scale(0.96);
}

.next-btn.disabled {
  opacity: 0.5;
  transform: none;
}

.demo-tip {
  font-size: 24rpx;
  color: #aaa;
  text-align: center;
  margin-top: 32rpx;
  margin-bottom: 16rpx;
}

.demo-buttons {
  display: flex;
  gap: 24rpx;
}

.demo-btn {
  flex: 1;
  height: 72rpx;
  background: rgba(126, 231, 188, 0.15);
  color: #5fd9a8;
  border-radius: 36rpx;
  font-size: 26rpx;
  border: 1rpx solid rgba(126, 231, 188, 0.3);
}

.demo-btn:active {
  background: rgba(126, 231, 188, 0.25);
}

/* 步骤2样式 */
.result-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid rgba(126, 231, 188, 0.2);
}

.result-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

.result-info {
  flex: 1;
}

.result-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
}

.result-status {
  font-size: 24rpx;
  color: #5fd9a8;
  background: rgba(95, 217, 168, 0.12);
  padding: 4rpx 16rpx;
  border-radius: 24rpx;
  display: inline-block;
}

.result-badge {
  background: #e8f5e9;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 22rpx;
  color: #4caf50;
}

.result-badge.mock {
  background: #fff3e0;
  color: #ff9800;
}

/* 信息卡片 */
.info-card {
  background: #f8f9fc;
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 28rpx;
}

.info-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #666;
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  gap: 20rpx;
}

.info-cell {
  flex: 1;
  text-align: center;
}

.cell-icon {
  font-size: 36rpx;
  display: block;
  margin-bottom: 8rpx;
}

.cell-label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 6rpx;
}

.cell-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
}

/* 关系卡片 */
.relation-card {
  background: #f8f9fc;
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 40rpx;
}

.relation-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #666;
  margin-bottom: 20rpx;
}

.relation-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #333;
  border: 1rpx solid #e8ecf0;
}

.picker-arrow {
  font-size: 32rpx;
  color: #bbb;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 24rpx;
}

.back-btn {
  flex: 1;
  height: 88rpx;
  background: #f5f7fa;
  color: #666;
  border-radius: 44rpx;
  font-size: 28rpx;
  border: none;
}

.confirm-btn {
  flex: 1;
  height: 88rpx;
  background: linear-gradient(135deg, #7ee7bc 0%, #5fd9a8 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(126, 231, 188, 0.3);
}

.confirm-btn:active,
.back-btn:active {
  transform: scale(0.96);
}

.confirm-btn[disabled] {
  opacity: 0.6;
}

/* 步骤3样式 */
.success-animation {
  text-align: center;
  margin-bottom: 32rpx;
}

.success-circle {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #7ee7bc 0%, #5fd9a8 100%);
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  animation: bounceIn 0.5s ease;
}

@keyframes bounceIn {
  0% { transform: scale(0); opacity: 0; }
  50% { transform: scale(1.1); }
  100% { transform: scale(1); opacity: 1; }
}

.success-check {
  font-size: 72rpx;
  color: #fff;
  font-weight: bold;
}

.success-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  display: block;
  margin-bottom: 12rpx;
}

.success-desc {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  display: block;
  margin-bottom: 40rpx;
}

.child-card-show {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #f8f9fc;
  border-radius: 28rpx;
  padding: 24rpx;
  margin-bottom: 40rpx;
}

.child-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.child-info-show {
  flex: 1;
}

.child-name-show {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
}

.child-relation-show {
  font-size: 24rpx;
  color: #5fd9a8;
  background: rgba(95, 217, 168, 0.12);
  padding: 4rpx 16rpx;
  border-radius: 24rpx;
  display: inline-block;
}

.continue-btn,
.finish-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
}

.continue-btn {
  background: #f5f7fa;
  color: #666;
}

.finish-btn {
  background: linear-gradient(135deg, #7ee7bc 0%, #5fd9a8 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(126, 231, 188, 0.3);
}

.continue-btn:active,
.finish-btn:active {
  transform: scale(0.96);
}

/* 毛玻璃兼容 */
@supports (backdrop-filter: blur(10px)) {
  .step-panel {
    background: rgba(255, 255, 255, 0.85);
  }
}
