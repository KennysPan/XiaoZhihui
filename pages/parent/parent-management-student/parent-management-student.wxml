<view class="page">
  <!-- 顶部返回按钮 -->
  <view class="custom-back" bindtap="btnBack" style="position: fixed; left: 29rpx; top: 102rpx">
    <view class="back-icon"></view>
    <text class="back-text">返回</text>
  </view>

  <!-- 头部 -->
  <view class="page-header">
    <text class="page-title">我的孩子</text>
    <view class="add-btn" bindtap="goToAddChild">
      <text class="add-icon">+</text>
      <text>添加孩子</text>
    </view>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-card" wx:if="{{children.length > 0}}">
    <view class="stats-item">
      <text class="stats-number">{{children.length}}</text>
      <text class="stats-label">已绑定孩子</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item">
      <text class="stats-number">{{presentCount}}</text>
      <text class="stats-label">今日到校</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 学生列表 -->
  <view class="student-list" wx:else>
    <view class="student-card" wx:for="{{children}}" wx:key="id" bindtap="viewChildDetail" data-child="{{item}}">
      <view class="card-left">
        <view class="avatar-placeholder" style="background: {{item.avatarColor}}">
          {{item.name[0]}}
        </view>
        <view class="info">
          <view class="name-row">
            <text class="name">{{item.name}}</text>
            <text class="relation-tag">{{item.relationName}}</text>
          </view>
          <text class="class-name">{{item.className || '未分班'}}</text>
          <text class="student-id" wx:if="{{item.studentId}}">学号：{{item.studentId}}</text>
        </view>
      </view>
      <view class="card-right" catchtap="stopPropagation">
        <view class="delete-btn" bindtap="deleteChild" data-child="{{item}}">
          <text>删除</text>
        </view>
        <text class="arrow-icon">›</text>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{children.length === 0}}">
      <text class="empty-text">暂无孩子信息</text>
      <text class="empty-desc">添加孩子后可以查看考勤、请假等</text>
      <button class="empty-add-btn" bindtap="goToAddChild">立即添加</button>
    </view>
  </view>
</view>

<!-- 孩子详情弹窗 -->
<view class="modal-mask" wx:if="{{showDetailModal}}" bindtap="closeDetailModal">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-header">
      <view class="modal-avatar" style="background: {{detailChild.avatarColor}}">
        <text>{{detailChild.name[0]}}</text>
      </view>
      <view class="modal-title-wrap">
        <text class="modal-title">{{detailChild.name}}</text>
        <text class="modal-relation">{{detailChild.relationName}}</text>
      </view>
      <view class="modal-close" bindtap="closeDetailModal">✕</view>
    </view>
    
    <scroll-view class="modal-body" scroll-y>
      <view class="detail-item">
        <text class="detail-label">性别</text>
        <text class="detail-value">{{detailChild.gender === 1 ? '男' : '女'}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">出生日期</text>
        <text class="detail-value">{{detailChild.birthday || '未填写'}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">班级</text>
        <text class="detail-value">{{detailChild.className || '未分配'}}</text>
      </view>
      <view class="detail-item" wx:if="{{detailChild.studentId}}">
        <text class="detail-label">学号</text>
        <text class="detail-value">{{detailChild.studentId}}</text>
      </view>
      <view class="detail-item" wx:if="{{detailChild.remark}}">
        <text class="detail-label">备注</text>
        <text class="detail-value">{{detailChild.remark}}</text>
      </view>
    </scroll-view>
    
    <view class="modal-footer">
      <button class="modal-btn cancel" bindtap="closeDetailModal">关闭</button>
      <button class="modal-btn confirm" bindtap="viewAttendance">查看考勤</button>
    </view>
  </view>
</view>
