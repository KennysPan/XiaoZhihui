page {
  height: 100vh;
  overflow: hidden;

  background: linear-gradient(to bottom, #87CEFA, #ffffff);
}

.page {
  height: 100vh;
  padding: 0 32rpx 48rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow: hidden;

  background: linear-gradient(to bottom, #87CEFA, #ffffff);
}

.custom-back { }

.back-icon {
  width: 20rpx;
  height: 20rpx;
  border-left: 5rpx solid #333;
  border-bottom: 5rpx solid #333;
  transform: rotate(45deg);
  margin-right: 14rpx;
}

.back-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
}

.hero-panel {
  flex-shrink: 0;
  margin-top: 34rpx;
  padding: 34rpx 30rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #74E2B6, #4DB6AC);
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 10rpx 28rpx rgba(77, 182, 172, 0.22);
}

.hero-title {
  display: block;
  font-size: 40rpx;
  color: #fff;
  font-weight: 700;
}

.hero-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.86);
}

.hero-icon {
  width: 92rpx;
  height: 92rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.24);
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.announcement-scroll {
  flex: 1;
  min-height: 0;
  margin-top: 28rpx;
}

.announcement-list {
  padding-bottom: 24rpx;
}

.announcement-card {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  background: #fff;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
}

.announcement-icon {
  width: 58rpx;
  height: 58rpx;
  margin-right: 18rpx;
  border-radius: 18rpx;
  background: #fff5d6;
  color: #b87900;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.announcement-content {
  flex: 1;
  min-width: 0;
}

.announcement-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.announcement-title {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  line-height: 1.35;
  word-break: break-all;
}

.announcement-time {
  margin-left: 16rpx;
  font-size: 21rpx;
  color: #aaa;
  line-height: 1.45;
  flex-shrink: 0;
}

.announcement-meta {
  display: block;
  margin-top: 8rpx;
  color: #4db6ac;
  font-size: 24rpx;
}

.announcement-desc {
  display: block;
  margin-top: 10rpx;
  color: #666;
  font-size: 25rpx;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.empty-state {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.empty-title {
  color: #555;
  font-size: 30rpx;
  font-weight: 600;
}

.empty-desc {
  margin-top: 12rpx;
  color: #999;
  font-size: 24rpx;
}

.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 30;
  background: rgba(0, 0, 0, 0.38);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
}

.detail-panel {
  width: 100%;
  max-height: 72vh;
  padding: 32rpx;
  border-radius: 24rpx;
  background: #fff;
  box-sizing: border-box;
}

.modal-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.detail-title-wrap {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: flex-start;
}

.detail-icon {
  margin-right: 16rpx;
}

.modal-title {
  flex: 1;
  min-width: 0;
  color: #333;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.35;
  word-break: break-all;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  line-height: 52rpx;
  margin-left: 18rpx;
  text-align: center;
  border-radius: 50%;
  color: #999;
  background: #f5f6f7;
  font-size: 42rpx;
  flex-shrink: 0;
}

.detail-meta {
  display: block;
  margin-bottom: 24rpx;
  color: #4db6ac;
  font-size: 24rpx;
  line-height: 1.45;
  word-break: break-all;
}

.detail-scroll {
  max-height: 46vh;
}

.detail-content {
  display: block;
  color: #555;
  font-size: 28rpx;
  line-height: 1.7;
  word-break: break-all;
  overflow-wrap: break-word;
  white-space: pre-wrap;
}
