<view class="page">
  <view class="header-bg"></view>

  <view class="custom-back teacher-nav" style="margin-top: {{menuButtonTop}}px; height: {{menuButtonHeight}}px; padding: 0 210rpx 72rpx 24rpx; box-sizing: border-box; position: relative; left: 0rpx; top: -6rpx" bindtap="goBack">
  <view class="back-icon" style="position: relative; left: 14rpx; top: 34rpx"></view>
  <text class="back-text" style="position: relative; left: 5rpx; top: 34rpx">学生评价</text>
</view>

  <scroll-view scroll-y class="content-scroll">
    <view class="student-card">
      <view class="student-main">
        <image class="avatar" src="{{selectedStudent.photo || 'https://www.kennyspan.xyz:8082/icon.png'}}" mode="aspectFill"></image>
        <view class="student-info">
          <picker mode="selector" range="{{students}}" range-key="name" value="{{studentIndex}}" bindchange="onStudentChange">
            <view class="student-name-row">
              <text class="student-name">{{selectedStudent.name || '请选择学生'}}</text>
              <text class="picker-arrow">切换</text>
            </view>
          </picker>
          <text class="student-meta">{{selectedStudent.className}} · 学号 {{selectedStudent.studentNumber || selectedStudent.id}}</text>
        </view>
      </view>

      <view class="summary-row">
        <view class="summary-item">
          <text class="summary-value">{{baseScore}}</text>
          <text class="summary-label">基础分</text>
        </view>
        <view class="summary-item">
          <text class="summary-value">+{{historyScoreDelta}}</text>
          <text class="summary-label">历史评分</text>
        </view>
        <view class="summary-item">
          <text class="summary-value">{{totalScore}}</text>
          <text class="summary-label">当前总分</text>
        </view>
        <view class="summary-item">
          <text class="summary-value">{{currentRecordCount}}</text>
          <text class="summary-label">历史评价</text>
        </view>
      </view>
    </view>

    <view class="form-section">
      <view class="section-title">评价信息</view>
      <view class="editing-tip" wx:if="{{editingRecordId}}">正在编辑历史评价，保存后将覆盖原记录</view>
      <view class="field-row">
        <text class="field-label">评价日期</text>
        <picker mode="date" value="{{evaluateDate}}" bindchange="onDateChange">
          <view class="picker-value">{{evaluateDate}}</view>
        </picker>
      </view>
      <view class="field-row">
        <text class="field-label">评价类型</text>
        <picker mode="selector" range="{{appraiseTypes}}" value="{{appraiseTypeIndex}}" bindchange="onTypeChange">
          <view class="picker-value">{{appraiseTypes[appraiseTypeIndex]}}</view>
        </picker>
      </view>
    </view>

    <view class="form-section">
      <view class="section-title">评分汇总</view>
      <view class="score-summary">
        <view class="score-summary-item">
          <text class="score-summary-label">基础分</text>
          <text class="score-summary-value">{{baseScore}}分</text>
        </view>
        <view class="score-summary-item">
          <text class="score-summary-label">历史评分</text>
          <text class="score-summary-value">+{{historyScoreDelta}}分</text>
        </view>
        <view class="score-summary-item">
          <text class="score-summary-label">本次评分</text>
          <text class="score-summary-value">+{{scoreDelta}}分</text>
        </view>
        <view class="score-summary-item total">
          <text class="score-summary-label">当前总分</text>
          <text class="score-summary-value">{{totalScore}}分</text>
        </view>
      </view>
    </view>

    <view class="form-section">
      <view class="section-title">能力维度</view>
      <view class="dimension-item" wx:for="{{dimensionList}}" wx:for-index="dimensionIndex" wx:key="key">
        <text class="dimension-name">{{item.name}}</text>
        <view class="dimension-control">
          <view class="score-row compact">
            <view
              wx:for="{{scoreItems}}"
              wx:for-item="score"
              wx:key="*this"
              class="score-option small {{!item.isCustom && score == item.score ? 'active' : ''}}"
              data-index="{{dimensionIndex}}"
              data-score="{{score}}"
              bindtap="onDimensionScoreTap"
            >{{score}}分</view>
            <view
              class="score-option small custom {{item.isCustom ? 'active' : ''}}"
              data-index="{{dimensionIndex}}"
              bindtap="onDimensionCustomTap"
            >自定义</view>
          </view>
          <input
            wx:if="{{item.isCustom}}"
            class="custom-score-input"
            type="digit"
            value="{{item.customScore}}"
            data-index="{{dimensionIndex}}"
            placeholder="输入分值"
            bindinput="onCustomScoreInput"
          />
        </view>
      </view>
    </view>

    <view class="form-section">
      <view class="section-title">表现标签</view>
      <view class="tag-wrap">
        <view
          wx:for="{{tagList}}"
          wx:key="text"
          class="tag {{item.selected ? 'selected' : ''}}"
          data-index="{{index}}"
          bindtap="onTagTap"
        >{{item.text}}</view>
      </view>
    </view>

    <view class="form-section">
      <view class="section-header">
        <view class="section-title">评价内容</view>
        <button class="text-btn" bindtap="generateComment">生成评语</button>
      </view>
      <textarea
        class="comment-input"
        value="{{comment}}"
        maxlength="300"
        placeholder="请输入学生评价内容"
        bindinput="onCommentInput"
      ></textarea>
      <view class="action-row">
        <button class="reset-btn" bindtap="resetForm">重置</button>
        <button class="save-btn" bindtap="saveAppraise">保存评价</button>
      </view>
    </view>

    <view class="history-section">
      <view class="history-title-row">
        <view class="section-title">历史评价</view>
        <text class="history-hint">长按可编辑或删除</text>
      </view>
      <view
        class="history-card {{item.isEditing ? 'editing' : ''}}"
        wx:for="{{records}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindlongpress="onHistoryLongPress"
      >
        <view class="history-head">
          <text class="history-title">{{item.type}} · +{{item.displayScoreDelta}}分</text>
          <text class="history-date">{{item.createdAt}}</text>
        </view>
        <view class="history-tags">
          <text wx:for="{{item.tags}}" wx:key="*this" class="history-tag">{{item}}</text>
        </view>
        <view class="history-comment">{{item.comment}}</view>
      </view>
      <view class="empty-tip" wx:if="{{records.length === 0}}">暂无评价记录</view>
    </view>
  </scroll-view>

  <view class="dialog-mask" wx:if="{{showRecordActionDialog}}" bindtap="closeRecordActionDialog">
    <view class="record-dialog" catchtap="noop">
      <view class="record-dialog-title">评价操作</view>
      <view class="record-dialog-desc">请选择要对这条历史评价执行的操作</view>
      <button class="dialog-action edit" bindtap="handleEditRecord">编辑评价</button>
      <button class="dialog-action delete" bindtap="handleDeleteRecord">删除评价</button>
      <button class="dialog-action cancel" bindtap="closeRecordActionDialog">取消</button>
    </view>
  </view>
</view>
