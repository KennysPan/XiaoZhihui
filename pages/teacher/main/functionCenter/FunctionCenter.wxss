page {
  min-height: 100vh;

  background: linear-gradient(to bottom, #87CEFA, #ffffff);
}

.page {
  min-height: 100vh;
  padding: 0 26rpx 32rpx;
  box-sizing: border-box;

  background: linear-gradient(to bottom, #87CEFA, #ffffff);
}

.function-nav.teacher-nav.custom-back {
  position: relative;
  left: auto;
  z-index: 20;
  padding: 0 210rpx 0 24rpx;
  margin-bottom: 34rpx;
  box-sizing: border-box;
}

.hero-panel {
  margin-top: 0;
  background: linear-gradient(135deg, #74E2B6, #4DB6AC);
  border-radius: 24rpx;
  padding: 38rpx 34rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 10rpx 28rpx rgba(77, 182, 172, 0.22);
}

.hero-title {
  display: block;
  font-size: 38rpx;
  color: #fff;
  font-weight: 700;
}

.hero-subtitle {
  display: block;
  margin-top: 12rpx;
  max-width: 500rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.88);
  line-height: 1.5;
}

.hero-icon {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
  flex-shrink: 0;
}

.function-grid {
  margin-top: 28rpx;
  display: grid;
  grid-template-columns: 1fr;
  gap: 20rpx;
}

.function-card {
  min-height: 150rpx;
  padding: 28rpx 30rpx;
  background: #fff;
  border-radius: 22rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-start;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.function-card::after {
  content: "";
  position: absolute;
  right: -34rpx;
  bottom: -34rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(116, 226, 182, 0.12);
}

.function-icon {
  width: 64rpx;
  height: 64rpx;
  margin-right: 24rpx;
  margin-bottom: 0;
  flex-shrink: 0;
}

.function-content {
  width: 100%;
  min-width: 0;
}

.function-name {
  display: block;
  font-size: 30rpx;
  color: #263238;
  font-weight: 700;
  line-height: 1.25;
}

.function-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #7a8a8a;
  line-height: 1.35;
}

.function-arrow {
  position: absolute;
  right: 28rpx;
  top: 50%;
  color: #c8d1d1;
  font-size: 36rpx;
  line-height: 1;
  transform: translateY(-50%);
}