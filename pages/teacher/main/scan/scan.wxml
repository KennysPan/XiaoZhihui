<view class="scan-page">
  <view class="scan-card">
    <view class="scan-icon"></view>
    <text class="scan-title">扫一扫</text>
    <text class="scan-desc">点击下方按钮后再打开扫码</text>
    <button class="scan-btn" loading="{{scanning}}" disabled="{{scanning}}" bindtap="startScan">
      {{scanning ? '扫码中...' : '开始扫码'}}
    </button>
    <view wx:if="{{scanResult}}" class="scan-result">
      <text class="result-label">扫码结果</text>
      <text class="result-text">{{scanResult}}</text>
    </view>
  </view>
</view>
