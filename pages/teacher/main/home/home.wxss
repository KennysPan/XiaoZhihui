/* pages/teacher/main/home/home.wxss */
.container {
	width: 100%;
	min-height: 100vh;
	background: linear-gradient(to bottom, #87CEFA, #ffffff);
	display: flex;
	flex-direction: column;
	align-items: center;
	padding-bottom: 180rpx;
	box-sizing: border-box;
	/* 确保容器没有顶部的 padding */
	padding-top: 0;
}

/* 修改背景图样式 */
.top-bg {
	width: 100%;
	height: 380rpx;
	/* 稍微加高一点，填充状态栏区域 */
	display: block;
}

.user-card {
	width: 92%;
	background: #ffffff;
	border-radius: 24rpx;
	margin-top: -80rpx;
	display: flex;
	align-items: center;
	padding: 24rpx 30rpx;
	box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.05);
	box-sizing: border-box;
	position: relative;
	z-index: 10;
}

.logo-wrapper {
	width: 100rpx;
	height: 100rpx;
	border-radius: 50%;
	border: 4rpx solid #fff;
	overflow: hidden;
	box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.1);
	flex-shrink: 0;
}

.logo {
	width: 100%;
	height: 100%;
}

.user-info {
	flex: 1;
	min-width: 0;
	margin-left: 20rpx;
}

.name-row,
.identity-row,
.school-row {
	display: flex;
	align-items: center;
	min-height: 36rpx;
}

.label {
	color: #999;
	font-size: 28rpx;
	flex-shrink: 0;
}

.value {
	color: #333;
	font-weight: 500;
	font-size: 28rpx;
}

.school-value {
	flex: 1;
	min-width: 0;
	overflow: hidden;
	text-overflow: ellipsis;
	white-space: nowrap;
}

.info-btn {
	background: #74E2B6;
	color: #fff;
	font-size: 24rpx;
	padding: 0 24rpx;
	height: 64rpx;
	line-height: 64rpx;
	border-radius: 32rpx;
	margin: 0;
	flex-shrink: 0;
}

.notice-ticker-card {
	width: 92%;
	height: 72rpx;
	margin: 18rpx auto 0;
	padding: 0 20rpx;
	border-radius: 20rpx;
	background: rgba(255, 255, 255, 0.58);
	border: 1rpx solid rgba(255, 255, 255, 0.72);
	box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.04);
	box-sizing: border-box;
	display: flex;
	align-items: center;
	overflow: hidden;
}

.notice-ticker-label {
	height: 42rpx;
	line-height: 42rpx;
	padding: 0 16rpx;
	border-radius: 21rpx;
	background: rgba(77, 182, 172, 0.14);
	color: #4db6ac;
	font-size: 23rpx;
	font-weight: 600;
	flex-shrink: 0;
}

.notice-ticker-window {
	flex: 1;
	min-width: 0;
	margin-left: 18rpx;
	overflow: hidden;
}

.notice-ticker-track {
	display: flex;
	align-items: center;
	width: max-content;
	animation: notice-marquee 10s linear infinite;
}

.notice-ticker-text {
	flex-shrink: 0;
	padding-right: 72rpx;
	font-size: 25rpx;
	color: #333;
	white-space: nowrap;
	line-height: 1;
	box-sizing: border-box;
}

@keyframes notice-marquee {
	0% {
		transform: translateX(0);
	}
	100% {
		transform: translateX(-50%);
	}
}

.func-area {
	width: 92%;
	margin: 18rpx auto 24rpx;
	background: #fff;
	border-radius: 24rpx;
	padding: 24rpx 0 30rpx;
	display: flex;
	flex-direction: column;
	box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.05);
	box-sizing: border-box;
}

.func-header {
	display: flex;
	align-items: center;
	justify-content: space-between;
	padding: 0 30rpx 22rpx;
}

.func-title {
	font-size: 30rpx;
	font-weight: 600;
	color: #333;
}

.func-more {
	min-height: 72rpx;
	padding-left: 24rpx;
	display: flex;
	align-items: center;
	color: #4db6ac;
	font-size: 24rpx;
}

.func-more-arrow {
	margin-left: 6rpx;
	font-size: 32rpx;
	line-height: 1;
}

.func-grid {
	display: flex;
	flex-wrap: wrap;
	padding: 0 18rpx;
	row-gap: 22rpx;
}

.func-item {
	display: flex;
	flex-direction: column;
	align-items: center;
	width: 25%;
	min-height: 118rpx;
	justify-content: center;
}

.func-icon {
	width: 70rpx;
	height: 70rpx;
	margin-bottom: 10rpx;
}

.func-text {
	font-size: 24rpx;
	color: #666;
}

.announcement-icon {
	width: 50rpx;
	height: 50rpx;
	margin-right: 18rpx;
	border-radius: 16rpx;
	background: #fff5d6;
	color: #b87900;
	font-size: 24rpx;
	font-weight: 700;
	display: flex;
	align-items: center;
	justify-content: center;
	flex-shrink: 0;
}

/* 班级区域固定框架 */
.student-section {
	width: 92%;
	margin: 0 auto;
	background: #fff;
	border-radius: 24rpx;
	padding: 30rpx;
	box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.05);
	box-sizing: border-box;
	min-height: 680rpx;
	display: flex;
	flex-direction: column;
}

.section-header {
	flex-shrink: 0;
	display: flex;
	justify-content: space-between;
	align-items: center;
	margin-bottom: 24rpx;
}

.section-title {
	font-size: 32rpx;
	font-weight: bold;
	color: #333;
	border-left: 8rpx solid #74E2B6;
	padding-left: 20rpx;
}

.student-count {
	font-size: 24rpx;
	color: #999;
}

.class-scroll-container {
	flex: 1;
	overflow: hidden;
}

.class-item {
	display: flex;
	align-items: center;
	padding: 24rpx 0;
	border-bottom: 1rpx solid #f5f5f5;
}

.class-avatar {
	width: 84rpx;
	height: 84rpx;
	border-radius: 20rpx;
	display: flex;
	align-items: center;
	justify-content: center;
	flex-shrink: 0;
	margin-right: 24rpx;
}

.class-initial {
	font-size: 32rpx;
	font-weight: bold;
	color: #fff;
}

.class-info {
	flex: 1;
}

.class-name {
	font-size: 34rpx;
	font-weight: 500;
	color: #333;
}

.course-tag {
	font-size: 20rpx;
	color: #74E2B6;
	background: rgba(116, 226, 182, 0.1);
	padding: 2rpx 10rpx;
	border-radius: 6rpx;
	margin-left: 12rpx;
}

.class-meta {
	font-size: 22rpx;
	color: #999;
}

.arrow-icon {
	font-size: 40rpx;
	color: #ccc;
}

.empty-state {
	height: 100%;
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;
}

.empty-icon {
	width: 160rpx;
	height: 160rpx;
}

.empty-text {
	font-size: 26rpx;
	color: #999;
	margin-top: 10rpx;
}

.custom-tabbar {
	position: fixed;
	bottom: 0;
	left: 0;
	width: 100%;
	height: 110rpx;
	background: #fff;
	display: flex;
	justify-content: space-around;
	align-items: center;
	box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
	z-index: 100;
	padding-bottom: env(safe-area-inset-bottom);
}

.tab-item {
	display: flex;
	flex-direction: column;
	align-items: center;
	flex: 1;
}

.tab-icon {
	width: 48rpx;
	height: 48rpx;
}

.tab-text {
	font-size: 22rpx;
	color: #999;
}

.tab-item.active .tab-text {
	color: #74E2B6;
}

.modal-mask {
	position: fixed;
	inset: 0;
	z-index: 200;
	background: rgba(0, 0, 0, 0.38);
	display: flex;
	align-items: flex-end;
}

.modal-header {
	display: flex;
	align-items: flex-start;
	justify-content: space-between;
	margin-bottom: 28rpx;
}

.modal-title {
	flex: 1;
	min-width: 0;
	font-size: 34rpx;
	color: #333;
	font-weight: 700;
	line-height: 1.35;
	word-break: break-all;
}

.modal-close {
	width: 56rpx;
	height: 56rpx;
	line-height: 52rpx;
	margin-left: 18rpx;
	text-align: center;
	border-radius: 50%;
	color: #999;
	background: #f5f6f7;
	font-size: 42rpx;
	flex-shrink: 0;
}

.detail-mask {
	align-items: center;
	justify-content: center;
	padding: 48rpx;
	box-sizing: border-box;
}

.detail-panel {
	width: 100%;
	max-height: 72vh;
	padding: 32rpx;
	border-radius: 24rpx;
	background: #fff;
	box-sizing: border-box;
}

.detail-title-wrap {
	flex: 1;
	min-width: 0;
	display: flex;
	align-items: flex-start;
}

.detail-icon {
	margin-right: 16rpx;
}

.detail-meta {
	display: block;
	margin-bottom: 24rpx;
	font-size: 24rpx;
	color: #4db6ac;
	line-height: 1.45;
	word-break: break-all;
}

.detail-scroll {
	max-height: 46vh;
}

.detail-content {
	display: block;
	font-size: 28rpx;
	color: #555;
	line-height: 1.7;
	word-break: break-all;
	overflow-wrap: break-word;
	white-space: pre-wrap;
}
