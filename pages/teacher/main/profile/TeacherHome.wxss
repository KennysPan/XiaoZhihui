/* pages/teacher/main/profile/TeacherHome.wxss */
/* 全局容器 */
.container {
  padding: 30rpx;
  padding-bottom: calc(360rpx + env(safe-area-inset-bottom));
  background: linear-gradient(to bottom, #87CEFA, #ffffff);
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 头部区域 */
.header {
  width: 100%;
  max-width: 662rpx;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 20rpx;
  padding: 20rpx;
  margin: 0 auto 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  position: relative;
  z-index: 1;
  box-sizing: border-box;
}

.avatar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 30rpx;
}

.avatar {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  border: 2rpx solid #eee;
}

.avatar-tip {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-top: 10rpx;
  line-height: 1.2;
}

.info-header {
  flex: 1;
}

.name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.welcome {
  font-size: 28rpx;
  color: #666;
}

.info-section {
  width: 100%;
  max-width: 662rpx;
  display: block;
  box-sizing: border-box;
  margin: -20rpx auto 0;
  position: relative;
  z-index: 1;
}

.my-button {
  width: 100%;
  max-width: 663rpx;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  background-color: #74E2B6;
  color: #fff;
  font-size: 26rpx;
  border-radius: 30rpx;
  border: none;
  padding: 0;
  margin: 8rpx auto 16rpx;
  position: relative;
  z-index: 1;
}

/* 清除按钮默认边框 */
.my-button::after {
  border: none;
}

.version-text {
  display: block;
  width: 100%;
  max-width: 663rpx;
  margin: 0 auto 34rpx;
  text-align: center;
  color: #7a8a92;
  font-size: 24rpx;
  line-height: 1.4;
  position: relative;
  z-index: 1;
}

/* 信息卡片 */
.info-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-item {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  line-height: 1.4;
}

.card-item:last-child {
  margin-bottom: 0;
}

/* 底部装饰 */
.decoration {
  position: fixed;
  left: 0;
  bottom: 136rpx;
  bottom: calc(136rpx + env(safe-area-inset-bottom));
  z-index: 0;
  pointer-events: none;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  opacity: 0.3;
  width: 100%;
  height: 270rpx;
  box-sizing: border-box;
  overflow: visible;
}

.decoration image {
  width: 382rpx;
  height: 270rpx;
}


/* 1. 顶部标题栏样式 - 调整高度和位置 */
.top-bar {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding: 0 40rpx;
  height: 200rpx;
  font-size: 32rpx;
  color: #333333;
  padding-top: constant(safe-area-inset-top);
  padding-top: env(safe-area-inset-top);
  box-sizing: border-box;
}