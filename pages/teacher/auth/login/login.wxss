/* pages/teacher/auth/login/login.wxss */

/* 页面整体样式 */
page { 
  overflow-x: hidden;

  background: linear-gradient(to bottom, #87CEFA, #ffffff);
}

/* 页面主容器 */
.login-page {
  position: relative;
  min-height: 100vh;
  width: 100vw;

  background: linear-gradient(to bottom, #87CEFA, #ffffff);
}

/* 中间图标容器 - 与index页面保持一致 */
.icon-wrapper {
  position: relative;
  display: flex;
  z-index: 1;
  align-items: center;
  justify-content: center; /* 水平居中 */
  margin: 100rpx auto 30rpx; /* 调整位置到最上方 */
  /* 或者使用固定定位使其在顶部 */
  /* position: fixed;
  top: 100rpx;
  left: 50%;
  transform: translateX(-50%); */
}

/* 图标样式 - 与index页面完全一致 */
.icon {
  /* 宽高必须相等，才能形成正圆形 */
  width: 175rpx;
  height: 175rpx;
  /* 关键属性：50% 圆角实现圆形 */
  border-radius: 50%;
  /* 可选：隐藏图片超出圆形的部分 */
  overflow: hidden;
  /* 与index一样：添加白色背景，让圆形更清晰 */
  background: rgba(255, 255, 255, 0.5);
  /* 与index一样：内边距，让图片与圆形边框有间距 */
  padding: 30rpx;
  /* 确保图片填充容器，不拉伸变形 */
  object-fit: cover;
}

/* 标题文字调整 - 放到Logo下方 */
.header {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 30rpx; /* 调整与Logo的间距 */
  margin-left: 0; /* 移除之前的左边距 */
}

@font-face {
  font-family: "阿里妈妈东方大楷 Regular";
  font-weight: 400;
  src: url("https://at.alicdn.com/wf/webfont/V3yK0QGX0cNa/oCjJGVwbVcC8.woff2") format("woff2"),
       url("https://at.alicdn.com/wf/webfont/V3yK0QGX0cNa/xBu8HyNInDXv.woff") format("woff");
  font-display: swap;
}

.title {
  font-size: 150rpx; /* 稍微调小一点，防止真机溢出 */
  color: #1E3A8A;
  /* 确保名称与 API 中定义的一致 */
  font-family: "阿里妈妈东方大楷 Regular", sans-serif; 
  letter-spacing: 10rpx;
  display: block;
  text-align: center;
}

/* 1. 顶部标题栏样式 - 调整高度和位置 */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: flex-end; 
  padding: 0 40rpx;
  height: 200rpx; /* 减小高度 */
  font-size: 32rpx;
  color: #333333;
  padding-top: constant(safe-area-inset-top);
  padding-top: env(safe-area-inset-top);
  box-sizing: border-box;
}

/* 2. 返回按钮容器样式 */
.back-btn {
  height: 100%;
  display: flex;
  align-items: center;
}

/* 3. 返回图标样式 */
.back-icon { 
  font-size: 80rpx; /* 减小一点 */
}

/* 3. 登录卡片样式 */
.login-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  width: 85%;
  max-width: 600rpx;
  margin: 30rpx auto; /* 增加上边距，避免与标题重叠 */
  background-color: #ffffff;
  border-radius: 100rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 10;
}

.login-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 60rpx;
}

/* 输入框通用样式 */
.input-item {
  display: flex;
  align-items: center;
  width: 100%;
  height: 90rpx;
  background-color: #f7f7f7;
  border-radius: 12rpx;
  padding: 0 30rpx;
  margin-bottom: 30rpx;
  box-sizing: border-box;
}

.label {
  font-size: 28rpx;
  color: #666666;
  width: 140rpx;
}

.input-field {
  flex: 1;
  font-size: 28rpx;
	padding-right: 100rpx;
  color: #333333;
  border: none;
  outline: none;
}

.password-container {
  position: relative;
}

.login-actions-row {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: -10rpx;
  margin-bottom: 50rpx;
}

.quick-login-btn {
  width: 140rpx;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0;
  margin: 0;
  background: #eef8ff;
  color: #4A90E2;
  border-radius: 26rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.quick-login-btn::after {
  border: none;
}

/* 忘记密码 */
.forget-pwd {
  font-size: 24rpx;
  color: #999999;
}

.eye-icon {
  position: absolute;
  right: 44rpx;
  top: 50%;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  transform: translateY(-50%);
}

.password-icon {
  position: relative;
  width: 38rpx;
  height: 24rpx;
  border: 4rpx solid #6f8f86;
  border-radius: 50%;
  box-sizing: border-box;
}

.password-icon::before {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  width: 10rpx;
  height: 10rpx;
  background: #6f8f86;
  border-radius: 50%;
  transform: translate(-50%, -50%);
}

.password-icon-hide::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  width: 52rpx;
  height: 4rpx;
  background: #6f8f86;
  border-radius: 999rpx;
  transform: translate(-50%, -50%) rotate(-35deg);
}

.password-icon-show::after {
  content: "";
  position: absolute;
  left: -8rpx;
  top: -8rpx;
  width: 46rpx;
  height: 32rpx;
  border: 4rpx solid #6f8f86;
  border-left-color: transparent;
  border-right-color: transparent;
  border-bottom-color: transparent;
  border-radius: 50%;
  box-sizing: border-box;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  background: linear-gradient(45deg, #4A90E2, #50E3C2);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 12rpx;
  border: none;
  padding: 0;
}

/* 按钮伪元素，用于清除默认边框 */
.login-btn::after {
  border: none;
}

/* 底部背景装饰 */
.bottomIcon {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 500rpx;
  height: 500rpx;
  /* border-radius: 50%; */
  overflow: hidden;
  opacity: 0.3;
  object-fit: cover;
  z-index: 1;
}



.role-back {
  position: absolute;
  left: 52rpx;
  top: calc(112rpx + env(safe-area-inset-top));
  z-index: 200;
  display: flex;
  align-items: center;
  height: 64rpx;
  padding: 0 20rpx 0 12rpx;
  background: rgba(255, 255, 255, 0.72);
  border-radius: 32rpx;
  color: #1E3A8A;
  box-shadow: 0 8rpx 20rpx rgba(30, 58, 138, 0.12);
}

.role-back-icon {
  font-size: 42rpx;
  line-height: 1;
  margin-right: 4rpx;
}

.role-back-text {
  font-size: 24rpx;
  font-weight: 500;
}