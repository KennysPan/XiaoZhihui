page {
  height: 100vh;
  overflow: hidden;
  background: linear-gradient(to bottom, #87CEFA, #ffffff);
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding: 0 40rpx;
  box-sizing: border-box;
}

.back-icon {
  width: 20rpx;
  height: 20rpx;
  border-left: 5rpx solid #333;
  border-bottom: 5rpx solid #333;
  transform: rotate(45deg);
  margin-right: 12rpx;
}

.back-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.search-box {
  width: 674rpx;
  display: block;
  box-sizing: border-box;
  left: 0;
  top: -14rpx;
  position: relative;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 40rpx;
  padding: 42rpx 40rpx;
  margin-top: 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.05);
}

.input-row {
  display: flex;
  align-items: center;
  min-height: 72rpx;
}

.date-row {
  margin-top: 20rpx;
}

.label {
  font-size: 30rpx;
  color: #666;
  width: 140rpx;
  flex: none;
}

.teacher-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.input-field {
  flex: 1;
  min-width: 0;
  background: #f8f8f8;
  height: 76rpx;
  border-radius: 20rpx;
  padding: 0 25rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid #eee;
  box-sizing: border-box;
}

.picker-inner {
  width: 100%;
  font-size: 28rpx;
  color: #333;
}

.decor-img-top {
  position: absolute;
  right: 20rpx;
  top: -30rpx;
  width: 110rpx;
  height: 110rpx;
}

.class-list-container {
  flex: 1;
  height: 0;
  margin-top: 14rpx;
  margin-bottom: 20rpx;
}

.class-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  position: relative;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.class-card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.class-title-group {
  flex: 1;
  min-width: 0;
}

.class-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #27343a;
  line-height: 1.35;
}

.class-date {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #7b8b92;
}

.rate-box {
  width: 116rpx;
  height: 116rpx;
  border-radius: 58rpx;
  background: #e6f7f1;
  color: #1a9b71;
  display: flex;
  align-items: baseline;
  justify-content: center;
  flex: none;
  padding-top: 28rpx;
  box-sizing: border-box;
}

.rate-number {
  font-size: 38rpx;
  font-weight: 700;
}

.rate-unit {
  font-size: 22rpx;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-top: 26rpx;
}

.summary-item {
  min-width: 0;
  border-radius: 18rpx;
  padding: 16rpx 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

.summary-value {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.2;
}

.summary-label {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.2;
}

.summary-item.normal {
  background: #ecfbf4;
  color: #25a875;
}

.summary-item.late {
  background: #fff6e6;
  color: #c57a12;
}

.summary-item.early {
  background: #eaf4ff;
  color: #3176bd;
}

.summary-item.absent {
  background: #fff0f0;
  color: #d65353;
}

.class-card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 22rpx;
  color: #7b8b92;
  font-size: 24rpx;
}

.decor-img-card {
  position: absolute;
  right: 12rpx;
  bottom: 10rpx;
  width: 92rpx;
  height: 92rpx;
  opacity: 0.12;
  pointer-events: none;
}

.page-empty {
  margin-top: 120rpx;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  backdrop-filter: blur(10rpx);
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 88%;
  max-height: 82vh;
  background: #ffffff;
  border-radius: 36rpx;
  padding: 34rpx;
  box-sizing: border-box;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  gap: 20rpx;
}

.title {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 700;
  color: #27343a;
  border-left: 8rpx solid #74E2B6;
  padding-left: 16rpx;
  line-height: 1.35;
}

.close-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #aab3b8;
  flex: none;
}

.class-detail-summary {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.detail-stat {
  background: #f5f8f9;
  border-radius: 16rpx;
  padding: 14rpx 6rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-number {
  color: #27343a;
  font-size: 30rpx;
  font-weight: 700;
}

.detail-label {
  margin-top: 4rpx;
  color: #7b8b92;
  font-size: 22rpx;
}

.student-list-panel,
.student-detail-list {
  max-height: 880rpx;
}

.student-list-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  background: #f9fbfb;
  border-radius: 22rpx;
  padding: 22rpx;
  margin-bottom: 18rpx;
  box-sizing: border-box;
}

.student-list-main {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.student-list-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  flex: none;
}

.student-detail-link {
  color: #4db6ac;
  font-size: 22rpx;
}

.student-record-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  background: #f5f8f9;
  border-radius: 20rpx;
  padding: 20rpx 22rpx;
  margin-bottom: 18rpx;
  box-sizing: border-box;
}

.student-record-title {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.back-list-btn {
  min-width: 128rpx;
  height: 52rpx;
  line-height: 52rpx;
  margin: 0;
  padding: 0 18rpx;
  border-radius: 26rpx;
  background: #e0f2f1;
  color: #208c82;
  font-size: 22rpx;
  font-weight: 600;
  flex: none;
}

.back-list-btn::after {
  border: 0;
}

.student-detail-card {
  position: relative;
  background: #f9fbfb;
  border-radius: 22rpx;
  padding: 22rpx;
  margin-bottom: 18rpx;
  box-sizing: border-box;
}

.student-detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  padding-right: 112rpx;
}

.student-title {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.student-name {
  font-size: 30rpx;
  color: #27343a;
  font-weight: 700;
  line-height: 1.35;
}

.student-number {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #8a9aa1;
}

.student-status {
  min-width: 92rpx;
  height: 48rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  flex: none;
}

.status-normal {
  background: #ecfbf4;
  color: #25a875;
}

.status-late {
  background: #fff6e6;
  color: #c57a12;
}

.status-earlyLeave {
  background: #eaf4ff;
  color: #3176bd;
}

.status-absent {
  background: #fff0f0;
  color: #d65353;
}

.record-row {
  display: grid;
  grid-template-columns: 92rpx 104rpx 1fr;
  gap: 10rpx;
  align-items: center;
  margin-top: 16rpx;
  padding: 14rpx 16rpx;
  background: #fff;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.record-time {
  font-size: 28rpx;
  font-weight: 700;
  color: #27343a;
}

.record-direction {
  height: 42rpx;
  border-radius: 21rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e0f2f1;
  color: #208c82;
  font-size: 22rpx;
}

.record-device {
  min-width: 0;
  color: #8a9aa1;
  font-size: 22rpx;
  line-height: 1.3;
}

.record-empty {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  background: #fff;
  color: #8a9aa1;
  font-size: 24rpx;
}

.makeup-btn {
  position: absolute;
  right: 22rpx;
  top: 22rpx;
  min-width: 88rpx;
  height: 48rpx;
  line-height: 48rpx;
  margin: 0;
  padding: 0 18rpx;
  border-radius: 24rpx;
  background: #74E2B6;
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
}

.makeup-btn::after {
  border: 0;
}

.no-data,
.loading-tip {
  text-align: center;
  font-size: 26rpx;
  color: #999;
  padding: 40rpx 0;
}
