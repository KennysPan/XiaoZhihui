/* StudentDetail.wxss */
.detail-container {
  min-height: 100vh;
  /* 移除原本可能的居中对齐，改用自然排列 */
  padding: 30rpx;
  box-sizing: border-box;
}

.header-bg {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 600rpx; /* 背景也随之下拉，颜色过渡更深 */
  z-index: 0;
}

.info-card {
  position: relative;
  z-index: 1;
  width: 90%;
  margin: 0 auto; /* 水平居中 */
  background: #fff;
  border-radius: 40rpx;
  padding: 120rpx 40rpx 60rpx;
  
  /* --- 再次大幅下移 --- */
  /* 如果觉得还不够低，就把 450 改成 550 */
  margin-top: 450rpx; 
  
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.08);
  box-sizing: border-box;
}

.detail-avatar {
  position: absolute;
  top: -90rpx; 
  left: 50%;
  transform: translateX(-50%);
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 8rpx solid #fff;
  background: #fff;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.1);
}

.back-btn {
  margin-top: 60rpx; 
  width: 60% !important;
  background: #87CEFA;
  color: white;
  border-radius: 50rpx;
}

/* ... 其他样式保持不变 ... */

.detail-info-header {
  text-align: center;
  margin-bottom: 20rpx;
}

.detail-name {
  font-size: 42rpx;
  font-weight: bold;
  color: #333;
}

.detail-id {
  font-size: 28rpx;
  color: #999;
  margin-top: 10rpx;
}

.divider {
  width: 100%;
  height: 2rpx;
  background: #f0f0f0;
  margin: 40rpx 0;
}

.info-list {
  width: 100%;
}

.info-row {
  display: flex;
  margin-bottom: 30rpx;
  line-height: 1.6;
}

.label {
  color: #666;
  width: 160rpx;
  font-size: 30rpx;
  flex-shrink: 0;
}

.value {
  color: #333;
  font-size: 30rpx;
  flex: 1;
}

.back-btn {
  margin-top: 60rpx;
  width: 80% !important;
  background: #87CEFA;
  color: white;
  border-radius: 50rpx;
  font-weight: 500;
  box-shadow: 0 10rpx 20rpx rgba(135, 206, 250, 0.3);
}
