/* pages/teacher/student/management/ParentManagementStudent.wxss */
page {
  font-family: "PingFang SC", sans-serif;
}

/* 顶部返回按钮 */
.custom-back { }

.back-icon {
  width: 20rpx;
  height: 20rpx;
  border-left: 5rpx solid #333;
  border-bottom: 5rpx solid #333;
  transform: rotate(45deg);
  margin-right: 12rpx;
}

.back-text {
  font-size: 32rpx;
  color: #333;
}

/* 容器：顶部留出返回键空间 */
.container {
  padding: 24rpx 30rpx 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

/* 顶部虚线框：宽度与卡片一致 */
.user-profile {
  width: 100%; 
  background: #fff;
  border: 2rpx dashed #ccc;
  border-radius: 40rpx;
  padding: 32rpx 0;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 头像包装：确保大尺寸和圆角 */
.avatar-wrapper {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 1rpx solid #eee;
  overflow: hidden; /* 保证图片显示为圆形 */
  margin-bottom: 10rpx;
	padding:25rpx ;
  display: flex;
  justify-content: center;
  align-items: center;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.user-info {
  text-align: center;
}

.name {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
}

.role {
  font-size: 40rpx;
  color: #000000;
}

.class-filter {
  width: 100%;
  height: 82rpx;
  margin-bottom: 24rpx;
  padding: 0 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.filter-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.class-picker {
  flex: 1;
  min-width: 0;
}

.picker-value {
  height: 82rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #4db6ac;
  font-size: 28rpx;
  font-weight: 600;
}

.picker-arrow {
  font-size: 36rpx;
  color: #9aa4a8;
  transform: rotate(90deg);
}

/* 学生列表卡片：恢复宽大效果 */
.student-card {
  width: 100%; 
  background: #fff;
  border-radius: 40rpx;
  padding: 50rpx 30rpx; 
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.08);
  box-sizing: border-box;
	height: 910rpx;
}

/* 网格布局：每行 3 个 */
.student-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr); 
  gap: 30rpx; 
  width: 100%;
}

/* 学生项：圆角矩形按钮 */
.student-item {
  height: 140rpx; 
  background: #fff;
  border: 1rpx solid #f0f0f0;
  border-radius: 40rpx; 
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #333;
  box-shadow: 0 4rpx 15rpx rgba(126, 231, 188, 0.15);
	transition: all 0.1s ease;
}

.student-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  line-height: 1.25;
}

.student-class {
  max-width: 100%;
  margin-top: 10rpx;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(77, 182, 172, 0.1);
  color: #4db6ac;
  font-size: 20rpx;
  line-height: 1.4;
  box-sizing: border-box;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.empty-state {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 28rpx;
}

.item-hover{
	background-color: #f7f7f7 !important;
	transform: scale(0.95);
	box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1) !important;
}

/* 分页指示器 */
.pagination {
  display: flex;
  justify-content: center;
  margin-top: 50rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  background: #e0e0e0;
  border-radius: 50%;
  margin: 0 10rpx;
}

.dot.active {
  background: #999;
}
