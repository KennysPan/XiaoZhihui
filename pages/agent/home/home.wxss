/* pages/agent/home/home.wxss */
page {
  height: 100vh;
  overflow: hidden;
  background: linear-gradient(to bottom, #87CEFA, #ffffff);
}

.home-container {
  width: 100%;
  height: 100vh;
  padding: 0;
  overflow: hidden;
  box-sizing: border-box;
}

.home-scroll {
  width: 100%;
  height: 100vh;
  box-sizing: border-box;
}

.home-content {
  padding: calc(188rpx + env(safe-area-inset-top)) 30rpx calc(180rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.welcome-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
}

.welcome-info {
  flex: 1;
  min-width: 0;
}

.greeting {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.date {
  font-size: 26rpx;
  color: #78838c;
}

.welcome-avatar {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #7ee7bc, #5fd9a8);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 22rpx rgba(95, 217, 168, 0.28);
  flex-shrink: 0;
}

.avatar-icon {
  font-size: 36rpx;
  color: #fff;
  font-weight: 700;
}

.stats-section,
.func-section,
.order-section {
  margin-top: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-left: 14rpx;
  border-left: 6rpx solid #5fd9a8;
  line-height: 1.2;
}

.stats-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.stat-card {
  width: calc(50% - 12rpx);
  text-align: center;
  padding: 30rpx 16rpx;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
  border-radius: 24rpx;
}

.stat-value {
  font-size: 46rpx;
  font-weight: bold;
  color: #46c997;
  display: block;
  line-height: 1.15;
}

.stat-label {
  font-size: 24rpx;
  color: #56616a;
  display: block;
  margin-top: 12rpx;
}

.stat-trend {
  font-size: 22rpx;
  color: #8a949d;
  display: block;
  margin-top: 8rpx;
}

/* 横向滑动区域 */
.func-scroll {
  width: 100%;
  white-space: nowrap;
}

.func-grid {
  display: inline-flex;
  gap: 20rpx;
  padding-right: 30rpx;
}

.func-item {
  width: 156rpx;
  min-height: 156rpx;
  border-radius: 24rpx;
  padding: 24rpx 12rpx 20rpx;
  text-align: center;
  box-sizing: border-box;
  transition: transform 180ms ease, opacity 180ms ease;
  flex-shrink: 0;
}

.func-item:active {
  transform: scale(0.96);
  opacity: 0.88;
}

.func-icon {
  font-size: 30rpx;
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 36rpx;
  display: inline-block;
  margin-bottom: 14rpx;
  color: #fff;
  font-weight: 700;
}

.func-name {
  font-size: 24rpx;
  color: #333;
  display: block;
  line-height: 1.25;
  white-space: normal;
  word-break: keep-all;
}

.order-preview {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 30rpx;
  border-radius: 24rpx;
}

.preview-item {
  text-align: center;
  flex: 1;
}

.preview-item text:first-child {
  font-size: 26rpx;
  color: #56616a;
  display: block;
  margin-bottom: 8rpx;
}

.preview-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6b6b;
  
}

.preview-divider {
  width: 2rpx;
  height: 60rpx;
  background: #e0e0e0;
}

.preview-arrow {
  font-size: 48rpx;
  color: #b6c0c8;
  padding: 0 8rpx 0 16rpx;
}