page {
  height: 100vh;
  overflow: hidden;
  background: linear-gradient(to bottom, #87CEFA, #ffffff);
}

.agent-tab-page {
  width: 100%;
  height: 100vh;
  padding: calc(86rpx + env(safe-area-inset-top)) 30rpx calc(180rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.agent-page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #263238;
  margin-bottom: 28rpx;
  line-height: 1.2;
  flex-shrink: 0;
}

.order-scroll {
  flex: 1;
  min-height: 0;
  margin-top: 42rpx;
  box-sizing: border-box;
}

.order-list {
  padding-bottom: 24rpx;
}

.order-card {
  margin-bottom: 24rpx;
  border-radius: 24rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
  margin-bottom: 16rpx;
  gap: 16rpx;
}

.order-id {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  min-width: 0;
  overflow-wrap: break-word;
}

.order-status {
  font-size: 24rpx;
  padding: 6rpx 18rpx;
  border-radius: 30rpx;
  flex-shrink: 0;
}

.status-pending { background: #fff7e6; color: #fa8c16; }
.status-shipped { background: #e6f7ff; color: #1890ff; }
.status-completed { background: #f6ffed; color: #52c41a; }

.order-info text {
  display: block;
  font-size: 26rpx;
  color: #56616a;
  margin-bottom: 12rpx;
  line-height: 1.4;
  overflow-wrap: break-word;
}

.loading,
.empty {
  flex: 1;
  min-height: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  color: #7d8992;
  font-size: 28rpx;
}
