<view class="container">
  <view class="custom-back agent-exit-btn" bindtap="goBack">
    <view class="back-icon"></view>
    <text class="back-text">收益统计</text>
  </view>

  <view class="page-heading">
    <text class="page-title">收益统计</text>
  </view>

  <view class="stats-summary card-common">
    <text class="summary-label">累计收益</text>
    <text class="summary-value">¥{{totalIncome}}</text>
    <text class="summary-label sub">本月收益</text>
    <text class="summary-value sub-value">¥{{thisMonthIncome}}</text>
  </view>

  <view class="record-section">
    <view class="record-title">收益明细</view>
    <scroll-view class="record-list" scroll-y="true" enhanced="true" show-scrollbar="true">
      <view wx:if="{{loading}}" class="record-state">加载中...</view>
      <view wx:elif="{{records.length === 0}}" class="record-state">暂无收益明细</view>
      <view wx:else class="record-list-inner">
        <view class="record-item" wx:for="{{records}}" wx:key="orderId">
          <view class="record-main">
            <text class="record-date">{{item.date}}</text>
            <text class="record-order">订单号：{{item.orderId}}</text>
          </view>
          <text class="record-amount">+¥{{item.amount}}</text>
        </view>
      </view>
    </scroll-view>
  </view>
</view>
