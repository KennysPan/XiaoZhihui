page {
  height: 100vh;
  overflow: hidden;
  background: linear-gradient(to bottom, #87CEFA, #ffffff);
}

.school-page {
  width: 100%;
  height: 100vh;
  padding-top: 94rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.school-back .back-text {
  font-weight: 700;
}

.school-scroll {
  flex: 1;
  min-height: 0;
  margin-top: 112rpx;
  box-sizing: border-box;
}

.school-list {
  padding: 0 22rpx 28rpx;
  box-sizing: border-box;
}

.school-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  border-radius: 22rpx;
}

.school-info {
  flex: 1;
  min-width: 0;
  padding-right: 18rpx;
}

.school-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.school-address,
.school-contact,
.school-stock {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-top: 6rpx;
  line-height: 1.35;
  overflow-wrap: break-word;
}

.replenish-btn {
  background: linear-gradient(135deg, #7ee7bc, #5fd9a8);
  color: white;
  border-radius: 40rpx;
  font-size: 26rpx;
  padding: 12rpx 28rpx;
  width: auto;
  height: auto;
  line-height: 1.2;
  flex-shrink: 0;
}

.replenish-btn::after {
  border: none;
}

.loading,
.empty {
  flex: 1;
  min-height: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}
