/* pages/agent/repair/repair.wxss */
.repair-page {
  min-height: 100vh;
  background: linear-gradient(to bottom, #87CEFA, #ffffff);
  padding: calc(180rpx + env(safe-area-inset-top)) 30rpx 48rpx;
  box-sizing: border-box;
}

/* 返回按钮样式 */
.custom-back {
  position: fixed;
  top: calc(88rpx + env(safe-area-inset-top));
  left: 30rpx;
  height: 72rpx;
  padding: 0 22rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(38, 50, 56, 0.08);
  border-radius: 36rpx;
  box-shadow: 0 8rpx 20rpx rgba(38, 50, 56, 0.08);
  display: flex;
  align-items: center;
  z-index: 100;
}

.back-icon {
  width: 16rpx;
  height: 16rpx;
  border-left: 4rpx solid #263238;
  border-bottom: 4rpx solid #263238;
  transform: rotate(45deg);
  margin-right: 12rpx;
}

.back-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #263238;
}

.agent-page-title {
  font-size: 42rpx;
  font-weight: 800;
  color: #263238;
  margin-bottom: 30rpx;
  padding-left: 8rpx;
}

.repair-scroll {
  height: calc(100vh - 280rpx);
  width: 100%;
}

.state-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #8a9aa8;
  font-size: 28rpx;
}

.empty {
  color: #a0adb8;
}

.repair-card {
  border-radius: 28rpx;
  margin-bottom: 24rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(95, 217, 168, 0.14);
  box-shadow: 0 18rpx 40rpx rgba(49, 116, 139, 0.12);
  transition: all 0.2s ease;
}

.repair-card:active {
  transform: scale(0.98);
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
  padding: 4rpx 0;
}

.row:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 26rpx;
  color: #6a7680;
  font-weight: 500;
}

.value {
  font-size: 28rpx;
  color: #263238;
  font-weight: 500;
}

.status {
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.status-0 { background: #fff7e6; color: #fa8c16; }
.status-1 { background: #e6f7ff; color: #1890ff; }
.status-2 { background: #f6ffed; color: #52c41a; }

/* 底部弹窗样式 */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 1000;
  backdrop-filter: blur(8rpx);
  display: flex;
  align-items: flex-end;
}

.detail-panel {
  width: 100%;
  max-height: 80vh;
  background: #ffffff;
  border-radius: 48rpx 48rpx 0 0;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 20rpx;
  border-bottom: 2rpx solid #f0f4f8;
}

.panel-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #263238;
}

.panel-close {
  font-size: 48rpx;
  color: #8a9aa8;
  padding: 0 12rpx;
  line-height: 1;
}

.detail-content {
  flex: 1;
  padding: 24rpx 32rpx 48rpx;
  max-height: 70vh;
}

.detail-item {
  margin-bottom: 28rpx;
  display: flex;
  flex-direction: column;
}

.detail-label {
  font-size: 26rpx;
  color: #6a7680;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.detail-value {
  font-size: 30rpx;
  color: #1f2a32;
  background: #f4f8fb;
  padding: 18rpx 24rpx;
  border-radius: 24rpx;
  word-break: break-word;
  line-height: 1.5;
}

.status-badge {
  display: inline-block;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.status-group {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
  padding-bottom: 20rpx;
}

.status-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #f0f4f8;
  color: #56616a;
  border: none;
}

.status-btn::after {
  border: none;
}

.status-btn-0.active,
.status-btn-0:active { background: #fa8c16; color: white; }
.status-btn-1.active,
.status-btn-1:active { background: #1890ff; color: white; }
.status-btn-2.active,
.status-btn-2:active { background: #52c41a; color: white; }

.status-btn[disabled] {
  opacity: 0.5;
  background: #e0e8f0;
  color: #8a9aa8;
}