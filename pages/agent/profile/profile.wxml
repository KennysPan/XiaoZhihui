<view class="container agent-tab-page profile-page">
  <view class="user-header card-common">
    <view class="avatar">代</view>
    <text class="user-name">{{agentInfo.name || '代理商'}}</text>
    <text class="user-phone">{{agentInfo.phone || ''}}</text>
  </view>
  <view class="menu-list card-common">
    <view class="menu-item" bindtap="editProfile">
      <text>修改资料</text>
      <text class="arrow">›</text>
    </view>
  </view>
  <view class="logout-item" bindtap="logout">
    <text>退出登录</text>
  </view>
  <view class="version">版本 v1.0.0</view>

  <custom-tab-bar />
</view>
