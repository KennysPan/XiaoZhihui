page {

  background: linear-gradient(to bottom, #87CEFA, #ffffff);
}

/**app.wxss**/
.container {
  min-height: 100vh;
  box-sizing: border-box;
}

.card-common {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  border-radius: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 30rpx;
  padding: 30rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.custom-back {
  position: fixed;
  top: calc(88rpx + env(safe-area-inset-top));
  left: 52rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  z-index: 1000;
  box-sizing: border-box;
}

.back-icon {
  width: 16rpx;
  height: 16rpx;
  border-left: 4rpx solid #333;
  border-bottom: 4rpx solid #333;
  transform: rotate(45deg);
  margin-right: 12rpx;
}

.back-text {
  font-size: 28rpx;
  color: #333;
}

.agent-exit-btn {
  left: 30rpx;
  height: 72rpx;
  padding: 0 22rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(38, 50, 56, 0.08);
  border-radius: 36rpx;
  box-shadow: 0 8rpx 20rpx rgba(38, 50, 56, 0.08);
}

.agent-exit-btn .back-text {
  font-weight: 600;
  color: #263238;
}

.page-header {
  text-align: center;
  padding-top: calc(242rpx + env(safe-area-inset-top));
  margin-bottom: 30rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.page-subtitle {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.teacher-nav.custom-back {
  position: relative;
  top: auto;
  left: auto;
  z-index: 20;
  display: flex;
  align-items: center;
  width: 100%;
  min-height: 64rpx;
  padding: calc(env(safe-area-inset-top) + 88rpx) 210rpx 72rpx 24rpx;
  margin: 0;
  box-sizing: border-box;
}

.teacher-nav .back-icon {
  width: 18rpx;
  height: 18rpx;
  border-left: 5rpx solid #263238;
  border-bottom: 5rpx solid #263238;
  transform: rotate(45deg);
  margin: 0 14rpx 0 4rpx;
  flex-shrink: 0;
}

.teacher-nav .back-text {
  font-size: 32rpx;
  color: #263238;
  font-weight: 600;
  line-height: 1.2;
  max-width: 430rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
